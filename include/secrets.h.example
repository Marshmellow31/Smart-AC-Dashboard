#pragma once

// Copy this file to secrets.h and fill in your real credentials.
// secrets.h is gitignored — it will never be committed.

#define WIFI_SSID "YOUR_WIFI_SSID"
#define WIFI_PASSWORD "YOUR_WIFI_PASSWORD"

// Sinric Pro (https://portal.sinric.pro) — create a "Window AC Unit" device
// and paste the credentials here. Leave empty ("") to disable cloud control.
#define SINRIC_APP_KEY "YOUR_SINRIC_APP_KEY"
#define SINRIC_APP_SECRET "YOUR_SINRIC_APP_SECRET"
#define SINRIC_AC_DEVICE_ID "YOUR_SINRIC_DEVICE_ID"

// Optional: a second Sinric device of type "Fan" that mirrors the AC's fan.
// Google Home doesn't surface the AC unit's fan-speed range (Alexa does), so
// this is how Google Home gets a Low/Medium/High fan control. Create a Fan
// device in the portal and paste its id; leave empty to skip.
#define SINRIC_FAN_DEVICE_ID ""

// Optional: Apple HomeKit setup code (8 digits). Leave empty to use
// HomeSpan's default 466-37-726. Avoid trivial codes (12345678 etc.) —
// Apple rejects them.
#define HOMEKIT_PAIRING_CODE ""
